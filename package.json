{
  "name": "epy-model-back",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "concurrently \"tsc --watch\" \"nodemon\"",
    "dev:build": "tsc --watch",
    "dev:server": "nodemon",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker/index.js",
    "lint": "eslint \"src/**/*.{ts,js}\"",
    "format": "prettier --write .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "start-main-flow": "node ./packageScripts/runMainFlow.js",
    "download-raw-data": "node ./packageScripts/runDownloadRawData.js",
    "pre-processing": "node ./packageScripts/runExecPreProcessing.js",
    "test_seirhuf": "node ./packageScripts/runExecTest_seirhuf.js",
    "generate-graphic": "node ./packageScripts/runGenerateGraphicFiles.js",
    "generate-simulation": "node ./packageScripts/runGenerateSimulationFiles.js",
    "get-simulation": "python ./src/scripts/simulador.py"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bullmq": "^5.58.2",
    "cors": "^2.8.5",
    "danfojs-node": "^1.1.2",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "helmet": "^7.2.0",
    "ioredis": "^5.7.0",
    "node-cron": "^3.0.2",
    "pino": "^9.9.0",
    "pino-http": "^10.5.0",
    "prom-client": "^15.1.3",
    "python-shell": "^5.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/node": "^20.19.2",
    "@types/node-cron": "^3.0.11",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^9.1.2",
    "nodemon": "^3.1.10",
    "pino-pretty": "^11.3.0",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "vitest": "^2.0.0",
    "@vitest/coverage-v8": "^2.0.0"
  }
}
